# 应用配置
APP_NAME=Non-Differentiable Network RL System
VERSION=1.0.0
DEBUG=false

# 服务器配置
HOST=0.0.0.0
PORT=8080

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# PPO 配置
PPO_LEARNING_RATE=0.0003
PPO_GAMMA=0.99
PPO_EPSILON=0.2
PPO_EPOCHS=10
PPO_BATCH_SIZE=64
INITIAL_TEMPERATURE=1.0
TEMPERATURE_DECAY=0.995
MIN_TEMPERATURE=0.01
REGULARIZATION_COEF=0.1

# 遗传算法配置
GA_POPULATION_SIZE=50
GA_MUTATION_RATE=0.1
GA_CROSSOVER_RATE=0.7
GA_ELITE_SIZE=5
GA_MAX_GENERATIONS=100
GA_SEED_RANGE_MIN=0
GA_SEED_RANGE_MAX=10000

# 环境配置
DEFAULT_ENV=LunarLander-v2
MAX_STEPS=1000
TOTAL_EPISODES=1000

# 任务配置
MAX_CONCURRENT_TRAINING_TASKS=2
MAX_CONCURRENT_GENETIC_TASKS=2

# 模型保存配置
MODEL_SAVE_DIR=models
